---
import Layout from '../../layouts/Layout.astro';
import ContactInfo from '../../components/ContactInfo.astro';
---

<Layout title="Intoxalock Ignition Interlock in Somerset, PA | K & D Auto Electric" description="Certified Intoxalock ignition interlock device service in Somerset, PA. Installation, calibration, monitoring, and removal. PA state-approved provider. Call (814) 443-3615." canonical="https://kdautoelectric.com/services/intoxalock">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-20">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Intoxalock</span>
      </nav>
      <div class="max-w-3xl">
        <span class="text-kd-red font-semibold text-sm uppercase tracking-wider">Service</span>
        <h1 class="text-4xl sm:text-5xl font-black text-kd-white mt-2">Intoxalock Ignition Interlock</h1>
        <p class="text-lg text-kd-gray-300 mt-4 leading-relaxed">
          Certified Intoxalock service provider in Somerset, PA. Installation, calibration, monitoring, and removal for Pennsylvania state requirements.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-kd-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-kd-black mb-6">Intoxalock Services</h2>
          <p class="text-kd-gray-600 leading-relaxed mb-6">
            K &amp; D Auto Electric is a certified Intoxalock service center serving Somerset, PA and surrounding areas. We provide complete ignition interlock device services to help you meet Pennsylvania state requirements.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            <div class="flex items-start gap-3 p-4 bg-kd-gray-50 rounded-lg border border-kd-gray-200">
              <svg class="w-5 h-5 text-kd-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-sm text-kd-gray-700">Device installation</span>
            </div>
            <div class="flex items-start gap-3 p-4 bg-kd-gray-50 rounded-lg border border-kd-gray-200">
              <svg class="w-5 h-5 text-kd-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-sm text-kd-gray-700">Calibration services</span>
            </div>
            <div class="flex items-start gap-3 p-4 bg-kd-gray-50 rounded-lg border border-kd-gray-200">
              <svg class="w-5 h-5 text-kd-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-sm text-kd-gray-700">Monitoring and compliance</span>
            </div>
            <div class="flex items-start gap-3 p-4 bg-kd-gray-50 rounded-lg border border-kd-gray-200">
              <svg class="w-5 h-5 text-kd-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-sm text-kd-gray-700">Device removal</span>
            </div>
          </div>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200">
            <h3 class="font-bold text-lg text-kd-black mb-2">PA State-Approved Provider</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              As a certified Intoxalock service center, we meet all Pennsylvania state requirements for ignition interlock device installation and maintenance. Our trained technicians ensure your device is properly installed, calibrated, and maintained throughout the required period.
            </p>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="bg-kd-gray-50 rounded-xl p-6 border border-kd-gray-200 sticky top-24">
            <h3 class="font-bold text-kd-black mb-4">Schedule Installation</h3>
            <p class="text-sm text-kd-gray-600 mb-4">
              Call us to schedule your Intoxalock installation or service appointment.
            </p>
            <a href="tel:8144433615" class="block w-full bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold text-center px-4 py-3 rounded-lg transition-colors">
              (814) 443-3615
            </a>
            <div class="mt-4 pt-4 border-t border-kd-gray-200 text-xs text-kd-gray-500">
              <p><strong class="text-kd-black">Toll Free:</strong><br />(888) 443-3615</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactInfo compact />
</Layout>
