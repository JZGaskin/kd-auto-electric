---
import Layout from '../../layouts/Layout.astro';
import ContactInfo from '../../components/ContactInfo.astro';

const services = [
  { title: 'Device Installation', desc: 'Professional installation in 3–4 hours. Our technician demonstrates proper use and provides a certificate of installation.' },
  { title: 'Calibration', desc: 'Regular calibration to ensure accurate readings and maintain compliance with state requirements.' },
  { title: 'Lockout Service', desc: 'Assistance if the device enters lockout mode, including diagnostic checks and reset procedures.' },
  { title: 'Maintenance & Support', desc: 'Ongoing device maintenance, troubleshooting, and customer support throughout the required period.' },
  { title: 'Device Removal', desc: 'We ensure removal on the exact required date and handle return shipping to Intoxalock.' },
];
---

<Layout title="Intoxalock Ignition Interlock in Somerset, PA | K & D Auto Electric" description="Certified Intoxalock ignition interlock device services in Somerset, PA. Installation, calibration, lockout, maintenance, and removal. Call (814) 443-3615." canonical="https://kdautoelectric.com/services/intoxalock">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-20">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Intoxalock</span>
      </nav>
      <div class="max-w-3xl">
        <span class="text-kd-red font-semibold text-sm uppercase tracking-wider">Service</span>
        <h1 class="text-4xl sm:text-5xl font-black text-kd-white mt-2">Intoxalock Ignition Interlock</h1>
        <p class="text-lg text-kd-gray-300 mt-4 leading-relaxed">
          Certified Intoxalock service center in Somerset, PA. Installation, calibration, lockout, maintenance, and removal &mdash; we handle the full process to help you meet Pennsylvania state requirements.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-kd-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-kd-black mb-6">Complete Intoxalock Services</h2>
          <p class="text-kd-gray-600 leading-relaxed mb-6">
            K &amp; D Auto Electric is a certified Intoxalock service center. We guide you through every step, from installation through removal, so you can focus on meeting your requirements.
          </p>

          <div class="space-y-4 mb-8">
            {services.map((s) => (
              <div class="p-5 bg-kd-gray-50 rounded-xl border border-kd-gray-200">
                <h3 class="font-bold text-kd-black mb-1">{s.title}</h3>
                <p class="text-sm text-kd-gray-600">{s.desc}</p>
              </div>
            ))}
          </div>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200">
            <h3 class="font-bold text-lg text-kd-black mb-2">How It Works</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              The Intoxalock ignition interlock device requires a breath sample before the vehicle will start. If alcohol is detected, the vehicle will not start. The device is easy to use, with a simple one-button design, and our technicians demonstrate proper use after installation.
            </p>
          </div>

          <div class="mt-6 p-6 bg-kd-yellow/10 rounded-xl border border-kd-yellow/30">
            <h3 class="font-bold text-lg text-kd-black mb-2">What to Bring for Removal</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              When coming in for device removal, please bring any necessary documents provided by your state or monitoring authority. We ensure removal occurs on the exact required date and handle shipping the device back to Intoxalock.
            </p>
          </div>

          <div class="mt-6">
            <a href="https://www.intoxalock.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-kd-red hover:text-kd-red-dark text-sm font-medium transition-colors">
              Learn more about Intoxalock devices
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="bg-kd-gray-50 rounded-xl p-6 border border-kd-gray-200 sticky top-24">
            <h3 class="font-bold text-kd-black mb-4">Schedule Installation</h3>
            <p class="text-sm text-kd-gray-600 mb-4">
              Call us to schedule your Intoxalock installation or service appointment.
            </p>
            <a href="tel:8144433615" class="block w-full bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold text-center px-4 py-3 rounded-lg transition-colors">
              (814) 443-3615
            </a>
            <div class="mt-4 pt-4 border-t border-kd-gray-200 space-y-2 text-xs text-kd-gray-500">
              <p><strong class="text-kd-black">Toll Free:</strong><br />(888) 443-3615</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactInfo compact />
</Layout>
