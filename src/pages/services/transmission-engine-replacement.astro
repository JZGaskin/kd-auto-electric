---
import Layout from '../../layouts/Layout.astro';
import ContactInfo from '../../components/ContactInfo.astro';

const services = [
  'Complete engine replacement — foreign and domestic',
  'Transmission replacement and installation',
  'Transmission diagnostics and programming',
  'Transmission fluid service — fluid check, filter change, pan cleaning',
  'Automatic and manual transmission service',
  'Engine diagnostics and performance tuning',

];
---

<Layout title="Transmission & Engine Replacement in Somerset, PA | K & D Auto Electric" description="Complete transmission and engine replacement in Somerset, PA. Expert installation, diagnostics, and programming for all makes and models. Call (814) 443-3615." canonical="https://kdautoelectric.com/services/transmission-engine-replacement">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-20">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Transmission &amp; Engine</span>
      </nav>
      <div class="max-w-3xl">
        <span class="text-kd-red font-semibold text-sm uppercase tracking-wider">Service</span>
        <h1 class="text-4xl sm:text-5xl font-black text-kd-white mt-2">Transmission &amp; Engine Replacement</h1>
        <p class="text-lg text-kd-gray-300 mt-4 leading-relaxed">
          Complete transmission and engine replacement services. Expert diagnostics, careful installation, and affordable options to extend the life of your vehicle.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-kd-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-kd-black mb-6">Engine &amp; Transmission Services</h2>
          <p class="text-kd-gray-600 leading-relaxed mb-8">
            When your vehicle needs major powertrain work, trust the experienced mechanics at K &amp; D Auto Electric. We guide you toward affordable options that match your budget and needs, whether that means a replacement engine or a rebuild.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {services.map((s) => (
              <div class="flex items-start gap-3 p-4 bg-kd-gray-50 rounded-lg border border-kd-gray-200">
                <svg class="w-5 h-5 text-kd-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-sm text-kd-gray-700">{s}</span>
              </div>
            ))}
          </div>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200 mb-6">
            <h3 class="font-bold text-lg text-kd-black mb-2">Engine Replacement</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              Engines have a defined lifespan. When yours reaches the end, we help you find the right replacement and install it carefully from start to finish. We explain all your options so you only buy what you need.
            </p>
          </div>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200">
            <h3 class="font-bold text-lg text-kd-black mb-2">Transmission Service</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              From fluid checks and filter changes to complete transmission replacement, we handle both automatic and manual transmissions. Our technicians perform thorough diagnostics and programming to keep your transmission running smoothly mile after mile.
            </p>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="bg-kd-gray-50 rounded-xl p-6 border border-kd-gray-200 sticky top-24">
            <h3 class="font-bold text-kd-black mb-4">Need an Estimate?</h3>
            <p class="text-sm text-kd-gray-600 mb-4">
              Call us to discuss your vehicle&apos;s needs and get an estimate.
            </p>
            <a href="tel:8144433615" class="block w-full bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold text-center px-4 py-3 rounded-lg transition-colors">
              (814) 443-3615
            </a>
            <div class="mt-4 pt-4 border-t border-kd-gray-200 space-y-2 text-xs text-kd-gray-500">
              <p><strong class="text-kd-black">Hours:</strong><br />Mon-Fri: 8AM-5PM<br />Sat: 8AM-12PM</p>
              <p><strong class="text-kd-black">Toll Free:</strong><br />(888) 443-3615</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactInfo compact />
</Layout>
