---
import Layout from '../../layouts/Layout.astro';
import ContactInfo from '../../components/ContactInfo.astro';

const services = [
  'Full emergency vehicle equipment installation',
  'Light bar and siren installation',
  'Radio and communication equipment mounting',
  'Police vehicle upfitting — partition, console, lighting, gun racks, window bars',
  'Fire apparatus electrical systems',
  'EMS vehicle conversion and equipment mounting',
  'Trailer lighting and electrical for response vehicles',
  'Fleet maintenance and replacement parts for emergency vehicles',
];
---

<Layout title="Emergency Vehicle Conversion in Somerset, PA | K & D Auto Electric" description="Emergency vehicle conversion and upfitting in Somerset, PA. Police, fire, and EMS equipment installation including light bars, gun racks, radios, window bars, and fleet maintenance." canonical="https://kdautoelectric.com/services/emergency-vehicle-conversion">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-20">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Emergency Vehicle Conversion</span>
      </nav>
      <div class="max-w-3xl">
        <span class="text-kd-red font-semibold text-sm uppercase tracking-wider">Service</span>
        <h1 class="text-4xl sm:text-5xl font-black text-kd-white mt-2">Emergency Vehicle Conversion</h1>
        <p class="text-lg text-kd-gray-300 mt-4 leading-relaxed">
          Professional emergency vehicle upfitting for police, fire, and EMS departments in Cambria and Somerset counties. From light bars to full communication systems, we equip first responders with reliable, mission-ready vehicles.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-kd-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-kd-black mb-6">Conversion &amp; Upfitting Services</h2>
          <p class="text-kd-gray-600 leading-relaxed mb-8">
            K &amp; D Auto Electric provides complete emergency vehicle conversion services for first responder agencies. We help transform vehicles into functional mobile command centers, handling everything from basic equipment installation to full vehicle upfitting. Our team works with each department to determine the optimal layout and equipment placement.
          </p>

          <ul class="space-y-4">
            {services.map((s) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-kd-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span class="text-kd-gray-700">{s}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8 p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200">
            <h3 class="font-bold text-lg text-kd-black mb-2">Supporting Local First Responders</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              Our team has decades of experience outfitting emergency vehicles for police, fire, and EMS agencies. We offer quality work at competitive prices, helping departments get the most out of their fleet budgets.
            </p>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="bg-kd-gray-50 rounded-xl p-6 border border-kd-gray-200 sticky top-24">
            <h3 class="font-bold text-kd-black mb-4">Department Inquiries</h3>
            <p class="text-sm text-kd-gray-600 mb-4">
              Call us to discuss your fleet&apos;s upfitting needs.
            </p>
            <a href="tel:8144433615" class="block w-full bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold text-center px-4 py-3 rounded-lg transition-colors">
              (814) 443-3615
            </a>
            <div class="mt-4 pt-4 border-t border-kd-gray-200 text-xs text-kd-gray-500">
              <p><strong class="text-kd-black">Toll Free:</strong><br />(888) 443-3615</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactInfo compact />
</Layout>
