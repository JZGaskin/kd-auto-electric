---
import Layout from '../layouts/Layout.astro';
import ContactInfo from '../components/ContactInfo.astro';
---

<Layout title="Emergency Vehicle Conversion in Somerset County, PA | K & D Auto Electric" description="K & D Auto Electric serves Somerset County, PA including Shanksville, Meyersdale, Windber, and more. Emergency vehicle conversion, auto repair, and electrical services. Call (814) 443-3615." canonical="https://kdautoelectric.com/somerset-county-pa">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-20">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Somerset County</span>
      </nav>
      <div class="max-w-3xl">
        <span class="text-kd-red font-semibold text-sm uppercase tracking-wider">Service Area</span>
        <h1 class="text-4xl sm:text-5xl font-black text-kd-white mt-2">Somerset County, PA</h1>
        <p class="text-lg text-kd-gray-300 mt-4 leading-relaxed">
          Proudly serving Somerset County with auto electric, repair, emergency vehicle conversion, and industrial equipment services. Based right here in Somerset, PA.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-kd-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-kd-black mb-6">Serving Somerset County Communities</h2>
          <p class="text-kd-gray-600 leading-relaxed mb-6">
            K &amp; D Auto Electric has been serving Somerset County since 1991. We provide auto electrical repair, mechanical repair, emergency vehicle conversion, and heavy equipment services to customers throughout the county, including Shanksville, Meyersdale, Windber, Berlin, Boswell, and all surrounding communities.
          </p>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200 mb-6">
            <h3 class="font-bold text-lg text-kd-black mb-2">Emergency Vehicle Conversion</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              We specialize in emergency vehicle conversion for first responders across Somerset County. Our services cover equipment installation for police cars, fire trucks, rescue vehicles, and trailers &mdash; helping departments transform vehicles into functional mobile command centers. We also provide general repair, maintenance, and replacement parts for emergency fleets.
            </p>
          </div>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200">
            <h3 class="font-bold text-lg text-kd-black mb-2">Full Automotive &amp; Industrial Services</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              Beyond emergency vehicles, we offer complete auto repair, electrical diagnostics, transmission and engine replacement, farming and industrial equipment repair, and Intoxalock ignition interlock services. No job is too big or too small.
            </p>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="bg-kd-gray-50 rounded-xl p-6 border border-kd-gray-200 sticky top-24">
            <h3 class="font-bold text-kd-black mb-4">Somerset County Service</h3>
            <p class="text-sm text-kd-gray-600 mb-4">
              Call us for expert automotive and emergency vehicle service throughout Somerset County.
            </p>
            <a href="tel:8144433615" class="block w-full bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold text-center px-4 py-3 rounded-lg transition-colors">
              (814) 443-3615
            </a>
            <div class="mt-4 pt-4 border-t border-kd-gray-200 space-y-2 text-xs text-kd-gray-500">
              <p><strong class="text-kd-black">Toll Free:</strong><br />(888) 443-3615</p>
              <p><strong class="text-kd-black">Hours:</strong><br />Mon-Fri: 8AM-5PM<br />Sat: 8AM-12PM</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactInfo compact />
</Layout>
