---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Website Disclaimer | K & D Auto Electric" description="Website disclaimer for K & D Auto Electric, Inc. in Somerset, PA." canonical="https://kdautoelectric.com/website-disclaimer">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-16">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Website Disclaimer</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-black text-kd-white">Website Disclaimer</h1>
    </div>
  </section>

  <section class="py-12 bg-kd-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-gray">
      <p class="text-sm text-kd-gray-500">Last updated: October 13, 2022</p>

      <h2>General Information</h2>
      <p>The information provided on this website is for general informational purposes only. All information provided on the site has been provided in good faith, however we make no guarantee or warranty of any kind regarding the reliability, accuracy, or completeness of any information on the site. We are in no way liable to you for any loss or damage of any kind incurred as a result of the use of this website or the reliance of any information provided through the direct use of this site. Your use of this site and your reliance of any information of this site is at your own risk.</p>

