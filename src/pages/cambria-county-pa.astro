---
import Layout from '../layouts/Layout.astro';
import ContactInfo from '../components/ContactInfo.astro';
---

<Layout title="Complete Transmission and Engine Replacement in Cambria County, PA | K & D Auto Electric" description="K & D Auto Electric serves Cambria County, PA including Johnstown, Ebensburg, Westmont, and more. Transmission and engine replacement, auto repair, and electrical services. Call (814) 443-3615." canonical="https://kdautoelectric.com/cambria-county-pa">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-20">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Cambria County</span>
      </nav>
      <div class="max-w-3xl">
        <span class="text-kd-red font-semibold text-sm uppercase tracking-wider">Service Area</span>
        <h1 class="text-4xl sm:text-5xl font-black text-kd-white mt-2">Cambria County, PA</h1>
        <p class="text-lg text-kd-gray-300 mt-4 leading-relaxed">
          Conveniently serving Cambria County including Johnstown, Ebensburg, and all surrounding communities. Quality auto electric, repair, and transmission services just minutes away.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-kd-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-kd-black mb-6">Serving Cambria County Communities</h2>
          <p class="text-kd-gray-600 leading-relaxed mb-6">
            Located just minutes from Cambria County, K &amp; D Auto Electric is a trusted choice for residents of Johnstown, Ebensburg, Westmont, and surrounding communities. We provide complete automotive, electrical, and heavy equipment services.
          </p>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200 mb-6">
            <h3 class="font-bold text-lg text-kd-black mb-2">Transmission &amp; Engine Replacement</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              Proper maintenance of your vehicle&apos;s engine and transmission is critical for longevity. We offer complete transmission diagnostics, programming, fluid services, and filter changes for both automatic and manual transmissions. For engines, we guide you toward affordable replacement options and handle the entire installation process.
            </p>
          </div>

          <div class="p-6 bg-kd-gray-50 rounded-xl border border-kd-gray-200">
            <h3 class="font-bold text-lg text-kd-black mb-2">Full Service Shop</h3>
            <p class="text-sm text-kd-gray-600 leading-relaxed">
              Beyond engines and transmissions, we serve Cambria County customers with auto electrical repair, general auto repair, PA state inspections, emergency vehicle conversion, farming and industrial equipment service, and Intoxalock ignition interlock installation and maintenance.
            </p>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="bg-kd-gray-50 rounded-xl p-6 border border-kd-gray-200 sticky top-24">
            <h3 class="font-bold text-kd-black mb-4">Cambria County Service</h3>
            <p class="text-sm text-kd-gray-600 mb-4">
              Call us for reliable automotive service at competitive prices.
            </p>
            <a href="tel:8144433615" class="block w-full bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold text-center px-4 py-3 rounded-lg transition-colors">
              (814) 443-3615
            </a>
            <div class="mt-4 pt-4 border-t border-kd-gray-200 space-y-2 text-xs text-kd-gray-500">
              <p><strong class="text-kd-black">Toll Free:</strong><br />(888) 443-3615</p>
              <p><strong class="text-kd-black">Hours:</strong><br />Mon-Fri: 8AM-5PM<br />Sat: 8AM-12PM</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactInfo compact />
</Layout>
