---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found | K & D Auto Electric" description="The page you are looking for could not be found. Visit our homepage or contact us.">
  <section class="py-24 bg-kd-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-8xl font-black text-kd-red/20">404</span>
      <h1 class="text-3xl sm:text-4xl font-black text-kd-black mt-4">Page Not Found</h1>
      <p class="text-kd-gray-500 mt-4 leading-relaxed">
        The page you are looking for may have been moved or no longer exists.
        Let us help you find what you need.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-8">
        <a href="/" class="bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold px-6 py-3 rounded-lg transition-colors">Return Home</a>
        <a href="/contact" class="border-2 border-kd-gray-300 text-kd-gray-700 hover:border-kd-red hover:text-kd-red font-semibold px-6 py-3 rounded-lg transition-colors">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>
