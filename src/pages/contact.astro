---
import Layout from '../layouts/Layout.astro';
import ContactInfo from '../components/ContactInfo.astro';
---

<Layout title="Contact K & D Auto Electric in Somerset, PA | (814) 443-3615" description="Contact K & D Auto Electric in Somerset, PA. Call (814) 443-3615 or (888) 443-3615. Located at 212 Forward Boulevard, Somerset, PA 15501." canonical="https://kdautoelectric.com/contact">
  <section class="relative bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20 py-20">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-kd-gray-400 mb-6">
        <a href="/" class="hover:text-kd-yellow transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-kd-yellow">Contact</span>
      </nav>
      <div class="max-w-3xl">
        <span class="text-kd-red font-semibold text-sm uppercase tracking-wider">Get In Touch</span>
        <h1 class="text-4xl sm:text-5xl font-black text-kd-white mt-2">Contact Us</h1>
        <p class="text-lg text-kd-gray-300 mt-4 leading-relaxed">
          We&apos;re here to help. Call, email, or stop by the shop &mdash; whatever works best for you.
        </p>
      </div>
    </div>
  </section>

  <ContactInfo />
</Layout>
