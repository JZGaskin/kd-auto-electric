---
export interface Props {
  title?: string;
  subtitle?: string;
  showVideo?: boolean;
  videoId?: string;
}

const { title = 'Auto Electric & Automotive Repair in Somerset, PA', subtitle = 'Family-owned and trusted since 1991. PA state inspections, engine performance, alternator rebuilding, and more.', showVideo = false, videoId = '1101530068' } = Astro.props;
---

<section class="relative overflow-hidden bg-kd-black min-h-[600px] flex items-center">
  <!-- Background Video -->
  {showVideo && (
    <div class="absolute inset-0 w-full h-full">
      <div class="absolute inset-0 bg-gradient-to-r from-kd-black/90 via-kd-black/70 to-kd-black/90 z-10"></div>
      <div class="aspect-video w-full h-full">
        <iframe
          class="w-full h-full object-cover"
          src={`https://player.vimeo.com/video/${videoId}?background=1&autoplay=1&loop=1&muted=1&byline=0&title=0&portrait=0`}
          allow="autoplay; fullscreen"
          allowfullscreen
          loading="lazy"
          title="K&D Auto Electric Video"
        ></iframe>
      </div>
    </div>
  )}

  <!-- Fallback background gradient -->
  {!showVideo && (
    <div class="absolute inset-0 bg-gradient-to-br from-kd-black via-kd-gray-900 to-kd-red/20"></div>
  )}

  <!-- Content -->
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-kd-red/20 text-kd-yellow text-sm font-medium px-4 py-1.5 rounded-full mb-6 border border-kd-yellow/20">
        <span class="w-2 h-2 bg-kd-yellow rounded-full"></span>
        Somerset, PA &mdash; Serving You Since 1991
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-kd-white leading-tight mb-6">
        {title}
      </h1>
      <p class="text-lg sm:text-xl text-kd-gray-300 max-w-2xl mb-8 leading-relaxed">
        {subtitle}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="tel:8144433615" class="inline-flex items-center gap-2 bg-kd-red hover:bg-kd-red-dark text-kd-white font-bold px-6 py-3 rounded-lg transition-colors shadow-lg shadow-kd-red/25">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (814) 443-3615
        </a>
        <a href="#services" class="inline-flex items-center gap-2 border-2 border-kd-white/20 text-kd-white hover:bg-kd-white/10 font-semibold px-6 py-3 rounded-lg transition-colors">
          Our Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-kd-white to-transparent z-10"></div>
</section>
