---
const testimonials = [
  {
    text: "Jeremy, Mike and everyone that works for K&D are special, caring people. Wish I could give them more than 5 star rating. They got my car back on the road so quickly; and with kind and professional customer service. Thanks!!",
    author: 'Peggy P.',
    source: 'Google',
    rating: 5,
  },
  {
    text: "5 stars DOES NOT come close, They deserve way more. I can't even to begin how much I appreciate everything the staff did for me today! Mike went above and beyond to help me. It's coming up on Christmas time and I was so stressed about my car and the price to fix it. He got it fixed right away and gave me the best price he could and billed the other business instead of making me pay for it! Thank you K&D for being the best shop around\u263a",
    author: 'Laken O.',
    source: 'Google',
    rating: 5,
  },
  {
    text: "These guys are the best of the best. I've been taking everything from cars, trucks, motorcycles and ATVs here for almost 10 years and they know what they are doing down to a science. Honest, hardworking people who aren't going to try to pull a fast one. They explain what they are doing and why they are doing it before they get into the work. Highly recommend going to these guys.",
    author: 'Jason Y.',
    source: 'Google',
    rating: 5,
  },
  {
    text: 'Called about scheduling a bike inspection. They said can you get here quick. I went right over and done. Will definitely go back!',
    author: 'Abishia D.',
    source: 'Google',
    rating: 5,
  },
];
---

<section class="py-20 bg-kd-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="text-kd-yellow font-semibold text-sm uppercase tracking-wider">What Our Customers Say</span>
      <h2 class="text-3xl sm:text-4xl font-black text-kd-white mt-2">Customer Reviews</h2>
      <p class="text-kd-gray-400 mt-3 max-w-2xl mx-auto">
        Hear from real customers who have trusted us with their vehicles.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {testimonials.map((t) => (
        <div class="bg-kd-gray-900 rounded-xl p-6 border border-kd-gray-800">
          <div class="flex gap-1 mb-3">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-4 h-4 text-kd-yellow" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-sm text-kd-gray-300 leading-relaxed mb-3">&ldquo;{t.text}&rdquo;</p>
          <p class="text-xs font-semibold text-kd-yellow">&mdash; {t.author}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-8">
      <a href="https://search.google.com/local/reviews?placeid=ChIJE5eH5pFzNIgR-V3-VYbY-cw" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-kd-yellow hover:text-kd-white text-sm font-medium transition-colors">
        Leave us a review on Google
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </div>
</section>
