---
const testimonials = [
  {
    text: 'K & D Auto Electric is by far the best shop around! They are honest, knowledgeable, and their prices are very fair. I would recommend them to anyone looking for quality auto repair work.',
    author: 'Google Reviews',
    rating: 5,
  },
  {
    text: 'Great people to deal with. They have helped me out many times with my vehicles and always do a great job. Highly recommend their services.',
    author: 'Google Reviews',
    rating: 5,
  },
  {
    text: 'Fast turnaround, fair pricing, and they explain everything clearly. This is the kind of shop every community needs — honest mechanics who care about their customers.',
    author: 'Google Reviews',
    rating: 5,
  },
];
---

<section class="py-20 bg-kd-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="text-kd-yellow font-semibold text-sm uppercase tracking-wider">What Our Customers Say</span>
      <h2 class="text-3xl sm:text-4xl font-black text-kd-white mt-2">4.9-Star Rated</h2>
      <p class="text-kd-gray-400 mt-3 max-w-2xl mx-auto">
        Our customers trust us with their vehicles. Here&apos;s what they have to say.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-kd-gray-900 rounded-xl p-6 border border-kd-gray-800">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-kd-yellow" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-sm text-kd-gray-300 leading-relaxed mb-4">&ldquo;{t.text}&rdquo;</p>
          <p class="text-xs font-semibold text-kd-yellow">&mdash; {t.author}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-8">
      <a href="https://search.google.com/local/reviews?placeid=ChIJE5eH5pFzNIgR-V3-VYbY-cw" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-kd-yellow hover:text-kd-white text-sm font-medium transition-colors">
        Leave us a review
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </div>
</section>
