---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '#services', dropdown: [
    { label: 'Automotive Electric', href: '/services/automotive-electric' },
    { label: 'Automotive Repair', href: '/services/automotive-repair' },
    { label: 'Farming & Industrial', href: '/services/farming-industrial' },
    { label: 'Emergency Vehicle Conversion', href: '/services/emergency-vehicle-conversion' },
    { label: 'Transmission & Engine', href: '/services/transmission-engine-replacement' },
    { label: 'Intoxalock', href: '/services/intoxalock' },
  ]},
  { label: 'Service Areas', href: '/service-areas' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="bg-kd-black text-kd-white sticky top-0 z-50 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img src="/images/KD_logo_dark.png" alt="K & D Auto Electric" class="h-14 w-auto" />
        <div class="hidden sm:block">
          <div class="font-bold text-sm leading-tight text-kd-white">K & D Auto Electric</div>
          <div class="text-xs text-kd-yellow">Somerset, PA &mdash; Since 1991</div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          item.dropdown ? (
            <div class="relative group">
              <a href={item.href} class="px-3 py-2 text-sm font-medium text-kd-white hover:text-kd-yellow transition-colors rounded-lg hover:bg-kd-gray-800 flex items-center gap-1">
                {item.label}
                <svg class="w-3.5 h-3.5 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="absolute left-0 mt-1 w-64 bg-kd-white rounded-lg shadow-xl border border-kd-gray-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="py-2">
                  {item.dropdown.map((child) => (
                    <a href={child.href} class="block px-4 py-2.5 text-sm text-kd-gray-700 hover:bg-kd-red hover:text-kd-white transition-colors">
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="px-3 py-2 text-sm font-medium text-kd-white hover:text-kd-yellow transition-colors rounded-lg hover:bg-kd-gray-800">
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Phone CTA -->
      <a href="tel:8144433615" class="hidden md:flex items-center gap-2 bg-kd-red hover:bg-kd-red-dark text-kd-white px-4 py-2 rounded-lg font-semibold text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        (814) 443-3615
      </a>

      <!-- Mobile Menu Button -->
      <button id="menu-toggle" class="lg:hidden p-2 rounded-lg hover:bg-kd-gray-800 transition-colors" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-kd-gray-800 bg-kd-black">
    <div class="px-4 py-3 space-y-1">
      <a href="/" class="block px-3 py-2 text-sm font-medium text-kd-white hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Home</a>
      <div class="space-y-1">
        <div class="px-3 py-2 text-sm font-medium text-kd-gray-400 uppercase tracking-wider text-xs">Services</div>
        <a href="/services/automotive-electric" class="block pl-6 px-3 py-2 text-sm text-kd-gray-300 hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Automotive Electric</a>
        <a href="/services/automotive-repair" class="block pl-6 px-3 py-2 text-sm text-kd-gray-300 hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Automotive Repair</a>
        <a href="/services/farming-industrial" class="block pl-6 px-3 py-2 text-sm text-kd-gray-300 hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Farming &amp; Industrial</a>
        <a href="/services/emergency-vehicle-conversion" class="block pl-6 px-3 py-2 text-sm text-kd-gray-300 hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Emergency Vehicle Conversion</a>
        <a href="/services/transmission-engine-replacement" class="block pl-6 px-3 py-2 text-sm text-kd-gray-300 hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Transmission &amp; Engine</a>
        <a href="/services/intoxalock" class="block pl-6 px-3 py-2 text-sm text-kd-gray-300 hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Intoxalock</a>
      </div>
      <a href="/service-areas" class="block px-3 py-2 text-sm font-medium text-kd-white hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Service Areas</a>
      <a href="/contact" class="block px-3 py-2 text-sm font-medium text-kd-white hover:text-kd-yellow rounded-lg hover:bg-kd-gray-800">Contact</a>
      <a href="tel:8144433615" class="block px-3 py-2 text-sm font-semibold text-kd-white bg-kd-red rounded-lg text-center mt-2">(814) 443-3615</a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  });
</script>
